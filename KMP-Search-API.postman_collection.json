									"});",
									"",
									"pm.test(\"Response has results\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.results).to.be.an('array');",
									"    pm.expect(jsonData.results.length).to.be.greaterThan(0);",
									"});",
									"",
									"pm.test(\"Results have highlights\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.results[0].highlights).to.exist;",
									"    pm.expect(jsonData.results[0].highlights.title).to.include('<em>');",
